{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"paths": {
			"$lib/components/ui/image-zoom": ["./src/lib/registry/image-zoom"],
			"$lib/components/ui/gallery": ["./src/lib/registry/gallery"],
			"$lib/components/ui/search": ["./src/lib/registry/search"],
			"$lib/components/ui/search/*": ["./src/lib/registry/search/*"],
			"$lib/components/ui/faq": ["./src/lib/registry/faq"],
			"$lib/components/ui/faq/*": ["./src/lib/registry/faq/*"],
			"$lib/components/ui/product": ["./src/lib/registry/product"],
			"$lib/components/ui/product/*": ["./src/lib/registry/product/*"],
			"$lib/components/ui/cta": ["./src/lib/registry/cta"],
			"$lib/components/ui/cta/*": ["./src/lib/registry/cta/*"],
			"$lib/components/ui/cart": ["./src/lib/registry/cart"],
			"$lib/components/ui/cart/*": ["./src/lib/registry/cart/*"],
			"$lib/components/ui/seo": ["./src/lib/registry/seo"],
			"$lib/components/ui/seo/*": ["./src/lib/registry/seo/*"],
			"$lib/components/ui/input-province": ["./src/lib/registry/input-province"],
			"$lib/components/ui/input-province/*": ["./src/lib/registry/input-province/*"],
			"$lib/components/ui/address": ["./src/lib/registry/address"],
			"$lib/components/ui/address/*": ["./src/lib/registry/address/*"],
			"$lib/components/ui/checkout": ["./src/lib/registry/checkout"],
			"$lib/components/ui/checkout/*": ["./src/lib/registry/checkout/*"],
			"$lib": ["./src/lib"],
			"$lib/*": ["./src/lib/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.svelte", "src/**/*.d.ts", "*.config.ts"]
}
