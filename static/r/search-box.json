{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "search-box",
	"title": "Search Box",
	"type": "registry:ui",
	"description": "Drop-in navbar search box: full input + live-results dropdown above a configurable breakpoint, collapsing to an icon that links to a search page below it. Assembles the search primitives.",
	"registryDependencies": [
		"search"
	],
	"files": [
		{
			"content": "<script lang=\"ts\">\n\timport * as Search from './index.js'\n\timport { cn } from '$UTILS$.js'\n\timport type { SearchFn, SearchHit } from './ctx.svelte.js'\n\timport type { Snippet } from 'svelte'\n\n\tinterface Props {\n\t\tbreakpoint?: 'sm' | 'md' | 'lg' | 'xl'\n\t\tsearchUrl?: string\n\t\tplaceholder?: string\n\t\tminLength?: number\n\t\tdebounce?: number\n\t\tlimit?: number\n\t\tsearch?: SearchFn\n\t\thref?: (hit: SearchHit) => string\n\t\ticon?: Snippet\n\t\tclass?: string\n\t}\n\tlet {\n\t\tbreakpoint = 'md',\n\t\tsearchUrl = '/search',\n\t\tplaceholder = 'Search',\n\t\t// minLength / debounce intentionally undefaulted — passed through to\n\t\t// <Search.Root>, which lets SearchState own the single default (2 / 200).\n\t\tminLength,\n\t\tdebounce,\n\t\tlimit,\n\t\tsearch,\n\t\thref,\n\t\ticon,\n\t\tclass: className = ''\n\t}: Props = $props()\n\n\tconst EXPANDED = {\n\t\tsm: 'hidden sm:block',\n\t\tmd: 'hidden md:block',\n\t\tlg: 'hidden lg:block',\n\t\txl: 'hidden xl:block'\n\t} as const\n\tconst COLLAPSED = {\n\t\tsm: 'sm:hidden',\n\t\tmd: 'md:hidden',\n\t\tlg: 'lg:hidden',\n\t\txl: 'xl:hidden'\n\t} as const\n</script>\n\n<!-- Expanded: full box with live-results dropdown. -->\n<div data-search-expanded class={cn(EXPANDED[breakpoint], 'w-full max-w-xl', className)}>\n\t<Search.Root {search} {minLength} {debounce} {limit}>\n\t\t<Search.Input {placeholder} {icon} />\n\t\t<Search.Results {href} />\n\t</Search.Root>\n</div>\n\n<!-- Collapsed: icon-only link to the full search page. -->\n<a\n\tdata-search-collapsed\n\thref={searchUrl}\n\taria-label=\"Search\"\n\tclass={cn(COLLAPSED[breakpoint], 'text-foreground inline-flex items-center p-2')}\n>\n\t{#if icon}\n\t\t<Search.Icon>{@render icon()}</Search.Icon>\n\t{:else}\n\t\t<Search.Icon />\n\t{/if}\n</a>\n",
			"type": "registry:ui",
			"target": "search/search-box.svelte"
		}
	]
}